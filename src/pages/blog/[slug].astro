---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAllBlogs } from '../../lib/blogs'
import styles from './slug.module.scss'

export function getStaticPaths() {
  const blogs = getAllBlogs()
  return blogs.map((blog, i) => ({
    params: { slug: blog.slug },
    props: {
      blog,
      // blogs are sorted newest-first; "prev" = older, "next" = newer
      prev: blogs[i + 1] ?? null,
      next: blogs[i - 1] ?? null,
    },
  }))
}

const { blog, prev, next } = Astro.props
---

<BaseLayout title={blog.title} description={blog.excerpt} activeSlug={blog.slug} showFontSize>
  <article class="post">
    <header class={styles['post-header']}>
      <time class={styles['post-date']} datetime={blog.date}>{blog.dateFormatted}</time>
      <h1 class={styles['post-title']}>{blog.title}</h1>
    </header>

    <div class={styles.prose} set:html={blog.html} />
  </article>

  <nav class={styles['post-nav']} aria-label="Previous and next entries">
    {
      prev ? (
        <a href={`/blog/${prev.slug}/`} class:list={[styles['post-nav-link'], styles.prev]} id="nav-prev">
          <span class={styles['post-nav-label']}>&larr; Previous</span>
          <span class={styles['post-nav-title']}>{prev.title}</span>
        </a>
      ) : (
        <span class={styles['post-nav-spacer']} />
      )
    }
    {
      next ? (
        <a href={`/blog/${next.slug}/`} class:list={[styles['post-nav-link'], styles.next]} id="nav-next">
          <span class={styles['post-nav-label']}>Next &rarr;</span>
          <span class={styles['post-nav-title']}>{next.title}</span>
        </a>
      ) : (
        <span class={styles['post-nav-spacer']} />
      )
    }
  </nav>
</BaseLayout>

<script>
  // Alt + Arrow navigates to previous / next entry
  window.addEventListener('keydown', (e) => {
    if (!e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      e.preventDefault()
      const prevEl = document.getElementById('nav-prev') as HTMLAnchorElement | null
      if (prevEl) prevEl.click()
    } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      e.preventDefault()
      const nextEl = document.getElementById('nav-next') as HTMLAnchorElement | null
      if (nextEl) nextEl.click()
    }
  }, { capture: true })
</script>
