---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllBlogs } from '../lib/blogs'
import styles from './index.module.scss'

const blogs = getAllBlogs()
const [latest, ...rest] = blogs
const earlier = rest.slice(0, 2)
---

<BaseLayout>
  <section class={styles.hero}>
    <p class={styles['hero-eyebrow']}>MasterZack's</p>
    <h1 class={styles['hero-title']}>JeevanKatha</h1>
    <p class={styles['hero-sub']}>O mortal fool, beware of the Yap. Ye have been warned.</p>
  </section>

  <img src="/something.webp" alt="" class={styles['hero-image']} loading="eager" fetchpriority="high" width="1200" height="1600" />

  {
    latest && (
      <section class={styles.latest} aria-labelledby="latest-heading">
        <h2 class={styles['section-label']} id="latest-heading">
          Latest entry
        </h2>
        <a href={`/blog/${latest.slug}/`} class={styles['latest-card']}>
          <time class={styles['card-date']} datetime={latest.date}>
            {latest.dateFormatted}
          </time>
          <h3 class={styles['latest-title']}>{latest.title}</h3>
          <p class={styles['latest-excerpt']}>{latest.excerpt}</p>
          <span class={styles['card-meta']}>Read entry &rarr;</span>
        </a>
      </section>
    )
  }

  {
    earlier.length > 0 && (
      <section class={styles.archive} aria-labelledby="archive-heading">
        <h2 class={styles['section-label']} id="archive-heading">
          Earlier entries
        </h2>
        <ul class={styles['archive-list']}>
          {earlier.map((blog) => (
            <li>
              <a href={`/blog/${blog.slug}/`} class={styles['archive-card']}>
                <div class={styles['archive-text']}>
                  <h3 class={styles['archive-title']}>{blog.title}</h3>
                  <p class={styles['archive-excerpt']}>{blog.excerpt}</p>
                </div>
                <div class={styles['archive-side']}>
                  <time class={styles['card-date']} datetime={blog.date}>
                    {blog.dateFormatted}
                  </time>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
