---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllBlogs } from '../lib/blogs'

const blogs = getAllBlogs()
const [latest, ...rest] = blogs
---

<BaseLayout>
  <section class="hero">
    <p class="hero-eyebrow">A Life Story</p>
    <h1 class="hero-title">Welcome to MasterZack&apos;s Jeevankatha</h1>
    <p class="hero-sub">
      Notes on books, anime, code, and the quiet business of being alive.
      Written slowly, published occasionally.
    </p>
  </section>

  {
    latest && (
      <section class="latest" aria-labelledby="latest-heading">
        <h2 class="section-label" id="latest-heading">
          Latest entry
        </h2>
        <a href={`/blog/${latest.slug}/`} class="latest-card">
          <time class="card-date" datetime={latest.date}>
            {latest.dateFormatted}
          </time>
          <h3 class="latest-title">{latest.title}</h3>
          <p class="latest-excerpt">{latest.excerpt}</p>
          <span class="card-meta">
          <span class="card-meta">Read entry &rarr;</span>
        </a>
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="archive" aria-labelledby="archive-heading">
        <h2 class="section-label" id="archive-heading">
          Earlier entries
        </h2>
        <ul class="archive-list">
          {rest.map((blog) => (
            <li>
              <a href={`/blog/${blog.slug}/`} class="archive-card">
                <div class="archive-text">
                  <h3 class="archive-title">{blog.title}</h3>
                  <p class="archive-excerpt">{blog.excerpt}</p>
                </div>
                <div class="archive-side">
                  <time class="card-date" datetime={blog.date}>
                    {blog.dateFormatted}
                  </time>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style lang="scss">
  .hero {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    text-wrap: balance;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--muted);
    max-width: 34rem;
    text-wrap: pretty;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .latest {
    margin-bottom: 2.5rem;
  }

  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background-color: var(--surface);
    color: var(--text);
    box-shadow: var(--shadow);
    transition: border-color 0.2s ease, transform 0.2s ease;

    &:hover {
      text-decoration: none;
      border-color: var(--accent);
      transform: translateY(-2px);
    }
  }

  .latest-title {
    font-family: var(--font-serif);
    font-size: 1.625rem;
    font-weight: 600;
    line-height: 1.25;
    text-wrap: balance;
  }

  .latest-excerpt {
    color: var(--muted);
    line-height: 1.6;
  }

  .card-date {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .card-meta {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .archive-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .archive-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background-color: var(--surface);
    color: var(--text);
    transition: border-color 0.2s ease, background-color 0.2s ease;

    &:hover {
      text-decoration: none;
      border-color: var(--accent);
    }

    @media (min-width: 640px) {
      flex-direction: row;
      justify-content: space-between;
      gap: 1.5rem;
    }
  }

  .archive-text {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .archive-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
    text-wrap: balance;
  }

  .archive-excerpt {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .archive-side {
    display: flex;
    flex-direction: row;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;

    @media (min-width: 640px) {
      flex-direction: column;
      align-items: flex-end;
      gap: 0.25rem;
    }
  }
</style>
