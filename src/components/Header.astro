---
interface Props {
  showFontSize?: boolean
  hideSidebar?: boolean
}

const { showFontSize = false, hideSidebar = false } = Astro.props
---

<header class="topbar">
  <div class="topbar-start">
    {!hideSidebar && (
      <button id="sidebar-toggle" class="topbar-sidebar-toggle" aria-label="Open blog list" aria-expanded="false" aria-controls="sidebar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    )}

    <a href="/" class="brand">
      <span class="brand-text">
        <span class="brand-name">MasterZack&apos;s</span>
        <span class="brand-sub">JeevanKatha</span>
      </span>
    </a>
  </div>

  <div class="topbar-controls">
    {
      showFontSize && (
        <div class="fontsize-group" role="group" aria-label="Text size">
          <button id="size-down" class="size-btn" aria-label="Decrease text size" title="Smaller text">
            A<span class="size-sign">-</span>
          </button>
          <button id="size-reset" class="size-btn" aria-label="Reset text size" title="Default text">
            A
          </button>
          <button id="size-up" class="size-btn" aria-label="Increase text size" title="Larger text">
            A<span class="size-sign">+</span>
          </button>
        </div>
      )
    }

    <button id="theme-toggle" class="theme-btn" aria-label="Toggle light and dark theme" title="Toggle theme">
      <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4.5"></circle>
        <line x1="12" y1="2" x2="12" y2="4.5"></line>
        <line x1="12" y1="19.5" x2="12" y2="22"></line>
        <line x1="2" y1="12" x2="4.5" y2="12"></line>
        <line x1="19.5" y1="12" x2="22" y2="12"></line>
        <line x1="4.9" y1="4.9" x2="6.7" y2="6.7"></line>
        <line x1="17.3" y1="17.3" x2="19.1" y2="19.1"></line>
        <line x1="4.9" y1="19.1" x2="6.7" y2="17.3"></line>
        <line x1="17.3" y1="6.7" x2="19.1" y2="4.9"></line>
      </svg>
      <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>
      </svg>
    </button>
  </div>
</header>

<script>
  const root = document.documentElement

  // --- Progressive font size controls ---
  const downBtn = document.getElementById('size-down') as HTMLButtonElement | null
  if (downBtn) {
    const MIN = 0
    const MAX = 6
    const DEFAULT = 3
    const resetBtn = document.getElementById('size-reset') as HTMLButtonElement | null
    const upBtn = document.getElementById('size-up') as HTMLButtonElement | null

    function currentLevel(): number {
      const raw = Number(root.dataset.fontsize)
      return Number.isInteger(raw) && raw >= MIN && raw <= MAX ? raw : DEFAULT
    }

    function applyLevel(level: number) {
      const clamped = Math.min(MAX, Math.max(MIN, level))
      if (clamped === DEFAULT) {
        delete root.dataset.fontsize
      } else {
        root.dataset.fontsize = String(clamped)
      }
      try {
        localStorage.setItem('jk-fontsize', String(clamped))
      } catch {}
      if (downBtn) downBtn.disabled = clamped === MIN
      if (upBtn) upBtn.disabled = clamped === MAX
      resetBtn?.classList.toggle('active', clamped === DEFAULT)
    }

    downBtn.addEventListener('click', () => applyLevel(currentLevel() - 1))
    upBtn?.addEventListener('click', () => applyLevel(currentLevel() + 1))
    resetBtn?.addEventListener('click', () => applyLevel(DEFAULT))

    applyLevel(currentLevel())
  }

  // --- Theme toggle ---
  const themeBtn = document.getElementById('theme-toggle')
  themeBtn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark'
    root.dataset.theme = next
    try {
      localStorage.setItem('jk-theme', next)
    } catch {}
  })

  // --- Sidebar toggle ---
  document.getElementById('sidebar-toggle')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('sidebar:toggle'))
  })
</script>

<style lang="scss">
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 30;
    transition: background-color 0.25s ease, border-color 0.25s ease;

    @media (min-width: 768px) {
      padding: 0.625rem 2.5rem;
      gap: 1rem;
    }

    @media (max-width: 500px) {
      padding: 0.5rem 0.625rem;
      gap: 0.375rem;
    }
  }

  .topbar-start {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;

    @media (max-width: 500px) {
      gap: 0.375rem;
    }
  }

  .brand {
    display: flex;
    align-items: center;
    color: var(--text);
    min-width: 0;

    &:hover {
      text-decoration: none;
    }
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .brand-name {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.2;

    @media (max-width: 700px) {
      display: none;
    }
  }

  .brand-sub {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;

    @media (max-width: 500px) {
      font-size: 0.875rem;
    }
  }

  .topbar-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;

    @media (min-width: 768px) {
      gap: 0.75rem;
    }
  }

  .topbar-sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: 50%;
    background-color: var(--surface);
    color: var(--muted);
    transition: background-color 0.15s ease, color 0.15s ease;

    &:hover {
      background-color: var(--surface-2);
      color: var(--text);
    }

    @media (max-width: 899px) {
      display: flex;
    }

    @media (max-width: 500px) {
      width: 2rem;
      height: 2rem;
    }
  }

  .fontsize-group {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 2);
    overflow: hidden;
    background-color: var(--surface);
  }

  .size-btn {
    display: flex;
    align-items: baseline;
    padding: 0.375rem 0.5rem;
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--muted);
    line-height: 1;
    transition: background-color 0.15s ease, color 0.15s ease, opacity 0.15s ease;

    @media (min-width: 768px) {
      padding: 0.375rem 0.75rem;
    }

    &:nth-child(1) {
      font-size: 0.75rem;
    }
    &:nth-child(2) {
      font-size: 0.875rem;
      border-left: 1px solid var(--border);
      border-right: 1px solid var(--border);
    }
    &:nth-child(3) {
      font-size: 1rem;
    }

    &:hover:not(:disabled) {
      background-color: var(--surface-2);
      color: var(--text);
    }

    &:disabled {
      opacity: 0.35;
      cursor: not-allowed;
    }

    &.active,
    &.active:hover {
      background-color: var(--accent);
      color: var(--bg);
    }
  }

  .size-sign {
    font-size: 0.85em;
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--border);
    border-radius: 50%;
    background-color: var(--surface);
    color: var(--muted);
    transition: background-color 0.15s ease, color 0.15s ease;

    &:hover {
      background-color: var(--surface-2);
      color: var(--text);
    }
  }

  // Show moon in light mode, sun in dark mode (dark-mode rules are global below)
  .icon-sun {
    display: none;
  }
</style>

<style lang="scss" is:global>
  html[data-theme='dark'] .theme-btn .icon-sun {
    display: block;
  }
  html[data-theme='dark'] .theme-btn .icon-moon {
    display: none;
  }
</style>
