---
import goodreadsIcon from '../icons/goodreads.svg?raw'
import anilistIcon from '../icons/anilist.svg?raw'
import telegramIcon from '../icons/telegram.svg?raw'
import githubIcon from '../icons/github.svg?raw'

const socials = [
  {
    name: 'Goodreads',
    href: 'https://www.goodreads.com/masterzack',
    icon: goodreadsIcon,
  },
  {
    name: 'AniList',
    href: 'https://anilist.co/user/masterzack',
    icon: anilistIcon,
  },
  {
    name: 'Telegram',
    href: 'https://t.me/masterzack',
    icon: telegramIcon,
  },
  {
    name: 'GitHub',
    href: 'https://github.com/masterzack',
    icon: githubIcon,
  },
]

const year = new Date().getFullYear()
---

<footer class="footer">
  <p class="footer-note">
    &copy; {year} MasterZack &mdash; <span class="footer-devanagari">जीवनकथा</span> continues&hellip;
  </p>
  <ul class="socials" aria-label="Social links">
    {
      socials.map((s) => (
        <li>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={s.name}
            title={s.name}
          >
            <span class="social-icon" set:html={s.icon} />
          </a>
        </li>
      ))
    }
  </ul>
</footer>

<style lang="scss">
  .footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.75rem 1.5rem;
    border-top: 1px solid var(--border);
    background-color: var(--surface);
    transition: background-color 0.25s ease, border-color 0.25s ease;

    @media (min-width: 640px) {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-note {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .footer-devanagari {
    font-style: normal;
  }

  .socials {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.375rem;
    height: 2.375rem;
    border-radius: 50%;
    color: var(--muted);
    border: 1px solid transparent;
    transition: color 0.15s ease, background-color 0.15s ease,
      border-color 0.15s ease, transform 0.15s ease;

    &:hover {
      color: var(--accent);
      background-color: var(--accent-soft);
      border-color: var(--border);
      transform: translateY(-2px);
    }
  }

  .social-icon {
    display: flex;
    width: 1.125rem;
    height: 1.125rem;

    :global(svg) {
      width: 100%;
      height: 100%;
      fill: currentColor;
    }
  }
</style>
