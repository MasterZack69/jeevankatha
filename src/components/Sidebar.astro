---
import { getAllBlogs } from '../lib/blogs'
import styles from './Sidebar.module.scss'

interface Props {
  activeSlug?: string
}

const { activeSlug } = Astro.props
const blogs = getAllBlogs().slice().reverse()
---

<div class={styles['sidebar-scrim']} id="sidebar-scrim" aria-hidden="true"></div>

<aside class={styles.sidebar} id="sidebar">
  <div class={styles['sidebar-top']}>
    <button id="sidebar-close" class={styles['sidebar-close-btn']} aria-label="Close blog list">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class={styles['search-wrap']}>
    <svg class={styles['search-icon']} width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
    </svg>
    <input
      type="search"
      id="blog-search"
      placeholder="Search..."
      aria-label="Search blog entries"
      autocomplete="off"
    />
  </div>

  <nav class={styles['blog-nav']} aria-label="Blog entries">
    <ul class={styles['blog-list']} id="blog-list">
      <li>
        <a
          href="/"
          class:list={[styles['blog-link'], { [styles.active]: Astro.url.pathname === '/' }]}
          aria-current={Astro.url.pathname === '/' ? 'page' : undefined}
        >
          <span class={styles['blog-link-title']}>Home</span>
        </a>
      </li>
      <li>
        <a
          href="/quotes/"
          class:list={[styles['blog-link'], { [styles.active]: Astro.url.pathname.startsWith('/quotes') }]}
          aria-current={Astro.url.pathname.startsWith('/quotes') ? 'page' : undefined}
        >
          <span class={styles['blog-link-title']}>Quotes</span>
        </a>
      </li>
      <li>
        <a
          href="/credits/"
          class:list={[styles['blog-link'], { [styles.active]: Astro.url.pathname.startsWith('/credits') }]}
          aria-current={Astro.url.pathname.startsWith('/credits') ? 'page' : undefined}
        >
          <span class={styles['blog-link-title']}>Credits</span>
        </a>
      </li>
      <li class={styles['nav-divider']} role="separator"></li>
      <li class={styles['nav-section-label']}>Stories</li>
      {
        blogs.map((blog) => (
          <li>
            <a
              href={`/blog/${blog.slug}/`}
              class:list={[styles['blog-link'], { [styles.active]: blog.slug === activeSlug }]}
              data-title={blog.title.toLowerCase()}
              data-date={blog.dateFormatted.toLowerCase()}
              aria-current={blog.slug === activeSlug ? 'page' : undefined}
            >
              <span class={styles['blog-link-title']}>{blog.title}</span>
              <time class={styles['blog-link-date']} datetime={blog.date}>
                {blog.dateFormatted}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
    <p class={styles['no-results']} id="no-results" hidden>No entries match your search.</p>
  </nav>
</aside>

<script define:vars={{ styles }}>
  // --- Search filtering ---
  const search = document.getElementById('blog-search') as HTMLInputElement | null
  const list = document.getElementById('blog-list')
  const noResults = document.getElementById('no-results')

  if (search && list) {
    const items = Array.from(list.querySelectorAll('li'))
    search.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase()
      let visible = 0
      for (const li of items) {
        const link = li.querySelector<HTMLAnchorElement>('.' + CSS.escape(styles['blog-link']))
        const title = link?.dataset.title
        const date = link?.dataset.date
        if (!title) {
          li.hidden = false
          continue
        }
        const match = !q || title.includes(q) || (date && date.includes(q))
        li.hidden = !match
        if (match) visible++
      }
      if (noResults) noResults.hidden = visible > 0
    })
  }

  // --- Mobile drawer ---
  const sidebar = document.getElementById('sidebar')
  const scrim = document.getElementById('sidebar-scrim')

  function setOpen(open: boolean) {
    sidebar?.classList.toggle(styles.open, open)
    scrim?.classList.toggle(styles.visible, open)
    const toggle = document.getElementById('sidebar-toggle')
    if (toggle) {
      toggle.setAttribute('aria-expanded', String(open))
      toggle.setAttribute('aria-label', open ? 'Close blog list' : 'Open blog list')
    }
  }

  document.addEventListener('sidebar:toggle', () => {
    setOpen(!sidebar?.classList.contains(styles.open))
  })
  scrim?.addEventListener('click', () => setOpen(false))
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false)
  })

  document.getElementById('sidebar-close')?.addEventListener('click', () => setOpen(false))

  // --- Swipe to close ---
  let touchStartX = 0
  let touchDeltaX = 0
  const SWIPE_THRESHOLD = 80

  sidebar?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX
  }, { passive: true })

  sidebar?.addEventListener('touchmove', (e) => {
    touchDeltaX = e.changedTouches[0].screenX - touchStartX
  }, { passive: true })

  sidebar?.addEventListener('touchend', () => {
    if (touchDeltaX < -SWIPE_THRESHOLD) setOpen(false)
    touchStartX = 0
    touchDeltaX = 0
  }, { passive: true })
</script>
