---
import '../styles/global.scss'
import Sidebar from '../components/Sidebar.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string
  description?: string
  activeSlug?: string
  showFontSize?: boolean
  hideSidebar?: boolean
}

const {
  title = "MasterZack's Jeevankatha",
  description = 'O mortal fool, beware of the Yap. Ye have been warned.',
  activeSlug,
  showFontSize = false,
  hideSidebar = false,
} = Astro.props

const pageTitle =
  title === "MasterZack's Jeevankatha"
    ? title
    : `${title} — MasterZack's Jeevankatha`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="MasterZack's JeevanKatha" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@400..700&display=swap"
    />
    <script is:inline>
      // Apply saved theme + font size before paint to avoid flashes
      ;(() => {
        const root = document.documentElement
        let theme = null
        let size = null
        try {
          theme = localStorage.getItem('jk-theme')
          size = localStorage.getItem('jk-fontsize')
        } catch {}
        if (theme !== 'light' && theme !== 'dark') {
          theme = 'dark'
        }
        root.dataset.theme = theme
        const level = Number(size)
        if (Number.isInteger(level) && level >= 0 && level <= 6 && level !== 3) {
          root.dataset.fontsize = String(level)
        }
      })()
    </script>
  </head>
  <body>
    <div class:list={['shell', { 'shell--bare': hideSidebar }]}>
      {!hideSidebar && <Sidebar activeSlug={activeSlug} />}
      <div class="main-col">
        <Header showFontSize={showFontSize} hideSidebar={hideSidebar} />
        <main class="content" id="main">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
