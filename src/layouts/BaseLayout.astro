---
import '../styles/global.scss'
import Sidebar from '../components/Sidebar.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import LoadingAnimation from '../components/LoadingAnimation.astro'

interface Props {
  title?: string
  description?: string
  activeSlug?: string
  showFontSize?: boolean
  hideSidebar?: boolean
}

const {
  title = "MasterZack's JeevanKatha",
  description = 'O mortal fool, beware of the Yap. Ye have been warned.',
  activeSlug,
  showFontSize = false,
  hideSidebar = false,
} = Astro.props

const pageTitle =
  title === "MasterZack's JeevanKatha"
    ? title
    : `${title} — MasterZack's JeevanKatha`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="MasterZack's JeevanKatha" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Inter:wght@400..700&display=swap"
    />
    <script is:inline>
      // Apply saved theme + font size before paint to avoid flashes
      ;(() => {
        const root = document.documentElement
        let theme = null
        let size = null
        try {
          theme = localStorage.getItem('jk-theme')
          size = localStorage.getItem('jk-fontsize')
        } catch {}
        if (theme !== 'light' && theme !== 'dark') {
          theme = 'dark'
        }
        root.dataset.theme = theme
        const level = size !== null ? Number(size) : NaN
        if (Number.isInteger(level) && level >= 0 && level <= 6 && level !== 3) {
          root.dataset.fontsize = String(level)
        }
      })()
    </script>
  </head>
  <body>
    <div class:list={['shell', { 'shell--bare': hideSidebar }]}>
      {!hideSidebar && <Sidebar activeSlug={activeSlug} />}
      <div class="main-col">
        <Header showFontSize={showFontSize} hideSidebar={hideSidebar} />
        <LoadingAnimation />
        <main class="content" id="main">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  <script>
    const loader = document.getElementById('loader')

    document.addEventListener('click', (e) => {
      const link = e.target.closest('a[href]')
      if (!link) return
      if (link.hostname !== location.hostname) return
      if (link.getAttribute('href')?.startsWith('#')) return
      if (link.dataset.noLoader !== undefined) return
      if (e.metaKey || e.ctrlKey || e.shiftKey) return
      loader?.classList.add('is-visible')
    })

    const NAV_PAGES = ['/', '/quotes', '/credits']

    window.addEventListener('keydown', (e) => {
      if (!e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return
      if (location.pathname.startsWith('/blog/')) return

      const current = location.pathname.replace(/\/$/, '') || '/'
      const idx = NAV_PAGES.indexOf(current)
      if (idx === -1) return

      const prev = (idx - 1 + NAV_PAGES.length) % NAV_PAGES.length
      const next = (idx + 1) % NAV_PAGES.length

      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault()
        loader?.classList.add('is-visible')
        location.href = NAV_PAGES[prev]
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault()
        loader?.classList.add('is-visible')
        location.href = NAV_PAGES[next]
      }
    }, { capture: true })
  </script>
  </body>
</html>
